# Local development
# Copy to .env for local shells, or set the same values in Vercel/Render/Cloudflare dashboards.

# API server
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# Neon Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST.neon.tech/DBNAME?sslmode=require

# BetterAuth
# Generate a long random value before production, for example:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=http://localhost:5000
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GITHUB_CLIENT_ID=your-github-client-id
GITHUB_CLIENT_SECRET=your-github-client-secret

# Browser origins allowed to call the API with cookies.
# Use comma-separated exact origins for deploy previews/production if needed.
FRONTEND_URL=http://localhost:8081
CORS_ORIGIN=http://localhost:8081

# SMTP (required for production password reset emails)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Vite frontend
VITE_API_URL=http://localhost:5000
BASE_PATH=/
VITE_ENABLE_SOCIAL_AUTH=false
VITE_ENABLE_PASSWORD_RESET=false
VITE_ENABLE_GOOGLE_SHEETS_INTEGRATION=false

# Deployment examples
# BETTER_AUTH_URL=https://your-api.onrender.com
# FRONTEND_URL=https://your-app.vercel.app
# CORS_ORIGIN=https://your-app.vercel.app,https://your-app.pages.dev
# VITE_API_URL=https://your-api.onrender.com
